# Copy this file to .env and fill in your API keys

# Database (default: SQLite)
# DATABASE_URL=sqlite:///./apartment_aggregator.db
# For PostgreSQL: DATABASE_URL=postgresql://user:pass@localhost:5432/apartment_aggregator

# Data Source API Keys
# ATTOM_API_KEY=your_attom_api_key_here
# REONOMY_API_KEY=your_reonomy_api_key_here
# ESTATED_API_TOKEN=your_estated_token_here
# PROPERTYSHARK_API_KEY=your_propertyshark_key_here

# Scheduler (hours between automatic fetches)
# FETCH_INTERVAL_HOURS=6
